rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitives
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // RBAC - Only if admin role is established in /admins/{uid}
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); 
    }

    // 2. RSVP Validation
    function isValidRSVP(data) {
      return data.keys().hasAll(['name', 'guests', 'attendance', 'createdAt'])
        && data.keys().size() <= 5 // name, guests, attendance, createdAt, optional: message
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.guests is string && data.guests.size() > 0 && data.guests.size() <= 50
        && data.attendance in ['yes', 'no']
        && (data.get('message', '') is string && data.get('message', '').size() <= 1000)
        && data.createdAt == request.time;
    }

    match /rsvps/{rsvpId} {
      // allow read: if isAdmin(); // Only admins can see the guest list
      allow create: if isValidRSVP(incoming()) && isValidId(rsvpId);
      allow update, delete: if false; // RSVPs are immutable for guests
    }
    
    // Placeholder for admin access
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false; // System defined
    }
  }
}
