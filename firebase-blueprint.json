{
  "entities": {
    "RSVP": {
      "title": "RSVP",
      "description": "A guest's RSVP response.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the guest."
        },
        "guests": {
          "type": "string",
          "description": "Number of guests attending."
        },
        "attendance": {
          "type": "string",
          "enum": ["yes", "no"],
          "description": "Whether the guest is attending or not."
        },
        "message": {
          "type": "string",
          "description": "Optional message for the couple."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the RSVP was submitted."
        }
      },
      "required": ["name", "guests", "attendance", "createdAt"]
    }
  },
  "firestore": {
    "rsvps/{rsvpId}": {
      "schema": "RSVP",
      "description": "Collection of wedding RSVPs."
    }
  }
}
